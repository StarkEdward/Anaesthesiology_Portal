{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "Library book",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "subject": { "type": "string" },
        "acc_no": { "type": "string" },
        "edition": { "type": "string" },
        "publisher": { "type": "string" },
        "total_quantity": { "type": "number" },
        "available_quantity": { "type": "number" },
        "added_date": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["title", "total_quantity", "available_quantity"]
    },
    "Instrument": {
      "title": "Instrument",
      "description": "Surgical instrument in the inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the instrument" },
        "company": { "type": "string", "description": "Manufacturer company" },
        "price": { "type": "number", "description": "Unit price" },
        "current_stock": { "type": "number", "description": "Available stock" },
        "invoice_date": { "type": "string", "description": "Date of invoice" },
        "po_date": { "type": "string", "description": "Date of purchase order" },
        "invoice_no": { "type": "string", "description": "Invoice number" },
        "po_no": { "type": "string", "description": "Purchase order number" },
        "stock_book_page_no": { "type": "string", "description": "Page number in stock book" },
        "is_active": { "type": "boolean", "description": "Whether the instrument is active (not soft-deleted)" }
      },
      "required": ["name", "company", "price", "current_stock"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Record of an instrument being issued or updated",
      "type": "object",
      "properties": {
        "instrument_id": { "type": "string", "description": "ID of the instrument" },
        "instrument_name": { "type": "string", "description": "Denormalized instrument name" },
        "quantity": { "type": "number", "description": "Quantity issued" },
        "issue_date": { "type": "string", "description": "Date of issue" },
        "incharge_sister_name": { "type": "string", "description": "Name of the incharge sister" },
        "incharge_sister_designation": { "type": "string", "description": "Designation of the sister" },
        "professor_name": { "type": "string", "description": "Name of the professor" },
        "remark": { "type": "string", "description": "General remark" },
        "status": { "type": "string", "enum": ["Pending", "Completed"], "description": "Current status" },
        "is_delivered_to_ot": { "type": "boolean", "description": "Whether delivered to OT" },
        "is_approved_by_professor": { "type": "boolean", "description": "Whether approved by professor" },
        "hod_remark": { "type": "string", "description": "Remark from HOD" },
        "ot_stock_book_no": { "type": "string", "description": "OT stock book number" },
        "ot_stock_book_page_no": { "type": "string", "description": "OT stock book page number" },
        "acceptance_date": { "type": "string", "description": "Date of acceptance" }
      },
      "required": ["instrument_id", "quantity", "issue_date", "status"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor associated with the department",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title (Dr.)" },
        "first_name": { "type": "string", "description": "First name" },
        "middle_name": { "type": "string", "description": "Middle name" },
        "last_name": { "type": "string", "description": "Last name" },
        "designation": { "type": "string", "description": "Designation" },
        "joining_date": { "type": "string", "description": "Date of joining" },
        "till_date": { "type": "string", "description": "Date of leaving" },
        "mobile_number": { "type": "string", "description": "Mobile number" },
        "email": { "type": "string", "description": "Email address" },
        "additional_info": { "type": "string", "description": "Additional information" }
      },
      "required": ["title", "first_name", "last_name", "designation", "joining_date"]
    },
    "PACRecord": {
      "title": "PAC Record",
      "description": "Pre-Anesthetic Checkup Record",
      "type": "object",
      "properties": {
        "patient_name": { "type": "string" },
        "age": { "type": "number" },
        "sex": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "uhid": { "type": "string" },
        "ward_bed": { "type": "string" },
        "date_of_admission": { "type": "string" },
        "surgery_date": { "type": "string" },
        "surgeon": { "type": "string" },
        "diagnosis": { "type": "string" },
        "procedure": { "type": "string" },
        "elective_emergency": { "type": "string", "enum": ["Elective", "Emergency"] },
        "comorbidities": { "type": "array", "items": { "type": "string" } },
        "pulse_rate": { "type": "number" },
        "blood_pressure": { "type": "string" },
        "spo2": { "type": "number" },
        "respiratory_rate": { "type": "number" },
        "temperature": { "type": "number" },
        "asa_grade": { "type": "string" },
        "risk": { "type": "string", "enum": ["Low", "Moderate", "High"] },
        "fitness": { "type": "string", "enum": ["Fit", "Unfit", "Conditional"] },
        "remarks": { "type": "string" },
        "consent_anesthesia": { "type": "boolean" },
        "consent_high_risk": { "type": "boolean" }
      },
      "required": ["patient_name", "age", "uhid", "diagnosis", "procedure", "fitness"]
    }
  },
  "firestore": {
    "/instruments/{instrumentId}": {
      "schema": "Instrument",
      "description": "Collection of surgical instruments"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of issue transactions"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Collection of doctors"
    },
    "/pac_records/{recordId}": {
      "schema": "PACRecord",
      "description": "Collection of PAC records"
    },
    "/library/{bookId}": {
      "schema": "Book",
      "description": "Collection of library books"
    }
  }
}
